{
  "description": "Smoke fixtures: minimal expected decision shape per regime. Full worked payloads live in ../examples/.",
  "cases": [
    {
      "regime": "risk_on",
      "exposure_multiplier": 1.0,
      "expect": { "has_risk_positions": true, "reserve_symbol": "USDT", "favourable_funding_tilted_up": true, "rich_funding_faded": true }
    },
    {
      "regime": "risk_off",
      "exposure_multiplier": 0.2,
      "expect": { "has_risk_positions": false, "reserve_symbol": "USDT", "full_reserve_possible": true, "carry_overridden_by_regime": true }
    },
    {
      "regime": "chop",
      "exposure_multiplier": 0.5,
      "expect": { "has_risk_positions": true, "reserve_symbol": "USDT", "reduced_risk_budget": true }
    },
    {
      "regime": "breakout",
      "exposure_multiplier": 1.1,
      "expect": { "has_risk_positions": true, "reserve_symbol": "USDT", "max_positions": 5, "crowded_longs_faded": true }
    }
  ],
  "required_outputs": ["market_regime", "carry_scores", "target_portfolio", "actions", "risk_policy"]
}
