{
  "description": "Required-output schema contract for the momentum-volatility-blend-bsc Skill.",
  "required_outputs": [
    "market_regime",
    "blend_scores",
    "target_portfolio",
    "actions",
    "risk_policy"
  ],
  "market_regime_enum": ["risk_on", "risk_off", "chop", "breakout"],
  "blend_score_fields": ["symbol", "momentum_leg", "vol_quality", "blend_tilt", "base_score", "security_penalty", "blend_score", "realised_vol_annual_pct"],
  "target_portfolio_fields": ["symbol", "weight_pct"],
  "action_types": ["entry", "exit", "rebalance", "trim", "no_entry", "reject", "heartbeat"],
  "invariants": {
    "score_range": [0.0, 1.0],
    "momentum_leg_range": [0.0, 1.0],
    "vol_quality_range": [0.0, 1.0],
    "blend_tilt_range": [0.0, 1.0],
    "weights_sum_pct": 100,
    "max_position_weight_pct": 17.0,
    "min_score_to_enter": 0.65,
    "min_score_to_hold": 0.50,
    "target_stable_reserve_pct": 12.0,
    "min_stable_reserve_pct": 10.0,
    "max_positions": 5,
    "tilt_combine": "momentum_leg * vol_quality (multiplicative gate)",
    "momentum_blend": "0.5*trend_score + 0.5*momentum_score",
    "vol_band": { "vol_floor": 40.0, "vol_lo": 50.0, "vol_hi": 80.0, "vol_ceiling": 110.0 },
    "ema_stack": [12, 26, 50],
    "macd": [12, 26, 9],
    "atr_period": 14,
    "realised_vol_window_hours": 168,
    "stop_loss_pct": 12.0,
    "take_profit_pct": 40.0,
    "atr_stop_multiple": 3.0,
    "drawdown_throttle_pct": 22.0,
    "kill_switch_pct": 24.0,
    "exposure_multipliers": { "breakout": 1.1, "risk_on": 1.0, "chop": 0.4, "risk_off": 0.15 },
    "reserve_symbol": "USDT"
  }
}
