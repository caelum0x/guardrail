{
  "uid": "guardrail-health",
  "title": "Guardrail Alpha — Agent Health",
  "tags": ["guardrail", "health"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Metrics Surfaces Up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
          ]
        },
        "overrides": []
      },
      "targets": [
        { "expr": "up{job=~\"guardrail-api|guardrail-exporter\"}", "legendFormat": "{{ job }}", "refId": "A" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Events Recorded",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 0 },
      "targets": [
        { "expr": "guardrail_events_total", "legendFormat": "events", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Snapshot Age (s)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "guardrail_report_age_seconds", "legendFormat": "age", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Events Recorded (over time)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 6 },
      "targets": [
        { "expr": "guardrail_events_total", "legendFormat": "events", "refId": "A" }
      ]
    }
  ]
}
