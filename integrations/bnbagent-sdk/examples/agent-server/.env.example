# examples/agent-server — copy to .env and fill in your values.

# --- Wallet (required) ---
WALLET_PASSWORD=demo-password
# First run only — after keystore is written under ~/.bnbagent/wallets, drop it.
PRIVATE_KEY=0x...
# Select a specific keystore if you have several.
# WALLET_ADDRESS=0x...

# --- Network ---
NETWORK=bsc-testnet
# RPC_URL=https://data-seed-prebsc-2-s2.binance.org:8545

# --- ERC-8183 contract overrides (bsc-testnet defaults apply; only set to override) ---
# ERC8183_COMMERCE_ADDRESS=0x...
# ERC8183_ROUTER_ADDRESS=0x...
# ERC8183_POLICY_ADDRESS=0x...

# --- Storage backend — pick ONE option in service.py ---
#
# (a) LocalStorageProvider (default — files written to .agent-data/, served locally)
#     ERC8183_AGENT_URL is required: the SDK rewrites file:// paths to this HTTP base URL.
ERC8183_AGENT_URL=http://localhost:8003/erc8183
#
# (b) IPFSStorageProvider — uncomment option (b) in service.py, then set:
# STORAGE_API_KEY=your_pinata_jwt_here        # https://app.pinata.cloud → API Keys → New Key
# STORAGE_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/

# --- ERC-8183 agent settings ---
ERC8183_SERVICE_PRICE=1000000000000000000  # minimum budget in raw token units (1 token @ 18 dp)
# ERC8183_FUNDED_POLL_INTERVAL=30          # funded-job poll cadence (seconds)
# ERC8183_NEGOTIATE_RATE_LIMIT=120         # /negotiate per-IP request budget
# ERC8183_NEGOTIATE_RATE_WINDOW=60         # rate-limit window (seconds)
# ERC8183_MAX_RESPONSE_BYTES=5242880       # response_content cap (5 MB)
# ERC8183_MAX_METADATA_BYTES=262144        # metadata cap (256 KB)

# --- Example-only (agent metadata + port) ---
AGENT_NAME=blockchain-news
AGENT_DESCRIPTION=Blockchain news search agent
AGENT_HOST=http://localhost:8003
PORT=8003
