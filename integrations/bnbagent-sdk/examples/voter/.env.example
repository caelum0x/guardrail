# examples/voter — copy to .env and fill in your values.

NETWORK=bsc-testnet
# RPC_URL=

# Whitelisted voter private key
VOTER_PRIVATE_KEY=0x...

# ERC-8183 contract overrides (bsc-testnet defaults apply)
# ERC8183_COMMERCE_ADDRESS=
# ERC8183_ROUTER_ADDRESS=
# ERC8183_POLICY_ADDRESS=

# IPFS gateway for downloading deliverable manifests
# STORAGE_GATEWAY_URL=https://gateway.pinata.cloud/ipfs/
