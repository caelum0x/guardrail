# ---------------------------------------------------------------------------
# Guardrail Alpha — full stack environment (deploy/compose).
#
# Copy this file to ".env" in the SAME directory and adjust as needed:
#     cp deploy/compose/.env.example deploy/compose/.env
#
# Every value here is a NON-secret default or an EMPTY placeholder. Real secrets
# (API keys, webhook URLs, SMTP passwords, RPC URLs) must be filled in locally
# in your own .env — which is git-ignored — and NEVER committed.
# ---------------------------------------------------------------------------

# --- Runtime ---------------------------------------------------------------
APP_ENV=paper
RUST_LOG=info
DATABASE_URL=sqlite://data/guardrail_alpha.db
GUARDRAIL_REPORT=data/run_report.json

# Which agent config the agent container loads (path inside the container,
# resolved against the read-only ../../configs mount).
AGENT_CONFIG=configs/paper.toml

# Monitor: number of readiness checks to run. 0 = run forever (default).
GUARDRAIL_MONITOR_CHECKS=0

# --- Published host ports --------------------------------------------------
# Change these if a port is already taken on your machine.
API_PORT=8080
EXPORTER_PORT=9100
DASHBOARD_PORT=3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Exporter bind address inside its container (leave as-is unless you know why).
EXPORTER_ADDR=0.0.0.0:9100

# --- Dashboard -------------------------------------------------------------
# Browser-facing API URL. The browser (not the container) resolves this, so it
# must be reachable from your host — keep localhost unless you front it behind
# a reverse proxy / different hostname.
NEXT_PUBLIC_API_URL=http://localhost:8080

# --- Grafana (monitoring profile) ------------------------------------------
# NON-secret default for LOCAL use only. Override with a strong password before
# exposing Grafana beyond localhost.
GRAFANA_ADMIN_PASSWORD=guardrail

# --- CMC (CoinMarketCap) ---------------------------------------------------
# Placeholder: paste your real key in your local .env, never here.
CMC_API_KEY=
CMC_X402_ENABLED=true
CMC_MCP_URL=

# --- TWAK wallet -----------------------------------------------------------
TWAK_MODE=local
TWAK_WALLET_NAME=guardrail-alpha
TWAK_MCP_URL=http://127.0.0.1:3000
TWAK_REST_URL=http://127.0.0.1:3001

# --- BSC chain -------------------------------------------------------------
# Placeholder RPC URL: supply your own endpoint in your local .env.
BSC_RPC_URL=
BSC_CHAIN_ID=56
COMPETITION_CONTRACT=0x212c61b9b72c95d95bf29cf032f5e5635629aed5

# --- Agent identity --------------------------------------------------------
AGENT_NAME=Guardrail Alpha
AGENT_METADATA_URL=
AGENT_POLICY_HASH=

# ---------------------------------------------------------------------------
# Alert relay (alerts profile). The relay holds NO keys; these are referenced
# by configs/alerts.example.json via env:VAR_NAME. All EMPTY by default so the
# default DRY-RUN loop is safe and offline.
#
# RELAY_ALERT_ARGS controls dry-run vs live. Leave as "--config" (the default)
# for the offline dry-run loop; set to "--live" with the relevant secrets below
# to actually deliver.
# ---------------------------------------------------------------------------
RELAY_ALERT_ARGS=--config
RELAY_ALERT_CONFIG=/app/configs/alerts.example.json

# In-network API base URL the relay polls (service name "api" on the compose net).
GUARDRAIL_API_BASE_URL=http://api:8080

# Sink credentials — PLACEHOLDERS ONLY. Fill in your local .env for --live.
GUARDRAIL_TELEGRAM_BOT_TOKEN=
GUARDRAIL_TELEGRAM_CHAT_ID=
GUARDRAIL_DISCORD_WEBHOOK_URL=
GUARDRAIL_GENERIC_WEBHOOK_URL=
GUARDRAIL_SLACK_WEBHOOK_URL=
GUARDRAIL_SMTP_HOST=
GUARDRAIL_SMTP_SENDER=
GUARDRAIL_SMTP_RECIPIENTS=
GUARDRAIL_SMTP_USERNAME=
GUARDRAIL_SMTP_PASSWORD=
