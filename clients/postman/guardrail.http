# Guardrail Alpha API -- REST Client requests
# VS Code REST Client / JetBrains HTTP Client compatible.
# One GET per route from docs/api/openapi.yaml. All endpoints are read-only.
#
# Set @baseUrl to your server. Click "Send Request" above each request
# (VS Code REST Client) or use the gutter run icon (JetBrains).

@baseUrl = http://localhost:8080

###############################################################################
# readiness/competition
###############################################################################

### /readiness
GET {{baseUrl}}/readiness
Accept: application/json

### /audit-manifest
GET {{baseUrl}}/audit-manifest
Accept: application/json

### /prizes
GET {{baseUrl}}/prizes
Accept: application/json

### /briefing
GET {{baseUrl}}/briefing
Accept: application/json

### /scorecard
GET {{baseUrl}}/scorecard
Accept: application/json

### /compete
GET {{baseUrl}}/compete
Accept: application/json

###############################################################################
# market data
###############################################################################

### /universe
GET {{baseUrl}}/universe
Accept: application/json

### /assets
GET {{baseUrl}}/assets
Accept: application/json

### /costs
# optional query params: amount_usd
GET {{baseUrl}}/costs
Accept: application/json

### /indicators
# optional query params: symbol (default WBNB), steps (default 60)
GET {{baseUrl}}/indicators
Accept: application/json

### /liquidity
GET {{baseUrl}}/liquidity
Accept: application/json

### /trending
GET {{baseUrl}}/trending
Accept: application/json

### /watchlist
# optional query params: limit (default 12)
GET {{baseUrl}}/watchlist
Accept: application/json

### /quotes
# optional query params: amount_usd
GET {{baseUrl}}/quotes
Accept: application/json

### /regime
GET {{baseUrl}}/regime
Accept: application/json

### /funding
GET {{baseUrl}}/funding
Accept: application/json

###############################################################################
# strategy/backtest
###############################################################################

### /policy
GET {{baseUrl}}/policy
Accept: application/json

### /policy/compile
GET {{baseUrl}}/policy/compile?mandate=Trade%20CAKE%20max%20drawdown%2020%25%20kill%20switch%2025%25
Accept: application/json

### /backtest
# optional query params: steps (default 60), fear_greed (default 60), preset (default balanced)
GET {{baseUrl}}/backtest
Accept: application/json

### /walkforward
# optional query params: windows (default 6), steps (default 30), preset (default balanced)
GET {{baseUrl}}/walkforward
Accept: application/json

### /sweep
# optional query params: steps (default 40), fear_greed (default 20,40,60,80), preset (default balanced)
GET {{baseUrl}}/sweep
Accept: application/json

### /job-simulator
GET {{baseUrl}}/job-simulator
Accept: application/json

### /mandates
GET {{baseUrl}}/mandates
Accept: application/json

### /optimize
# optional query params: symbols (default CAKE,WBNB,BTCB), scores, vols
GET {{baseUrl}}/optimize
Accept: application/json

### /experiments
GET {{baseUrl}}/experiments
Accept: application/json

### /rebalance
# optional query params: preset (default balanced), nav_usd
GET {{baseUrl}}/rebalance
Accept: application/json

### /scenarios
GET {{baseUrl}}/scenarios
Accept: application/json

